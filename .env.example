# ========================================================
# ENVIRONMENT CONFIGURATION — STRIVING FOR PHASE 0 LOCAL DEV
# Copy this file to .env and fill in all values.
# Run: cp .env.example .env
# ========================================================

# ── Supabase (Database & Auth Roles) ────────────────────
# The base URL of your Supabase project (find in Settings > API)
SUPABASE_URL=http://127.0.0.1:54321
# Anon key for client-side usage (public actions)
SUPABASE_PUBLISHABLE_KEY=your_anon_key_here
# Service Role key for backend scripts (bypasses RLS - NEVER expose to client)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
# Direct Postgres connection URL (e.g. for migrations or raw SQL)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# ── RabbitMQ (Message Queue) ────────────────────────────
# Used by Python worker to pull email sending jobs
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# ── Local Development SMTP (MailHog) ────────────────────
# In local development, the worker container sends mail to the local mailhog service
# running in docker-compose.yml so you don't actually spam real inboxes.
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=

# ── Production System Mailer (Gmail SMTP) ────────────────
# Use these instead of mailhog if testing real delivery!
# HOW TO GET YOUR APP PASSWORD:
# 1. Log into your Google Account -> "Security" tab -> "2-Step Verification"
# 2. Search for "App Passwords", create one named "Email Engine"
SYSTEM_SMTP_HOST=smtp.gmail.com
SYSTEM_SMTP_PORT=587
SYSTEM_SMTP_USERNAME=your_email@gmail.com
SYSTEM_SMTP_PASSWORD=the_16_character_app_password
SYSTEM_SMTP_FROM_EMAIL=your_email@gmail.com
SYSTEM_SMTP_FROM_NAME=Email Engine

# ── AWS SDK Credentials (Direct API Access) ─────────────
# Set these if sending via Amazon SES instead of SMTP
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# ── Redis (Campaign State + Rate Limiting) ──────────────
# Future-proofing for tracking open/click webhooks
REDIS_URL=redis://localhost:6379/0

# ── JWT Auth & Security Secrets ─────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=super_secret_jwt_key_replace_me_in_prod
UNSUBSCRIBE_SECRET=super_secret_unsub_key
TRACKING_SECRET=super_secret_tracking_key

# ── App URLs & Network routing ──────────────────────────
# Used by components fetching API data and links in emails
NEXT_PUBLIC_API_URL=http://localhost:8000
FRONTEND_BASE_URL=http://localhost:3000
API_URL=http://localhost:8000
BACKEND_URL=http://localhost:8000

# ── App Environment Settings ────────────────────────────
# Set to 'production' when deploying
ENV=development
ENVIRONMENT=development
DEBUG=True
TRACE_ID_HEADER=X-Trace-ID
